generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?  @unique
  password  String
  token     String?
  syncToken Int      @default(0)
  library   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}